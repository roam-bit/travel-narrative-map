# ============================================================
#  环境变量示例 —— 复制本文件为 .env 并填入你自己的值
#    cp .env.example .env
#  .env 已被 .gitignore 排除，不会上传到 GitHub。
# ============================================================

# ---------- 高德地图 JS API（地图渲染必需）----------
# 申请：https://console.amap.com/  →  创建应用  →  添加「Web端(JS API)」key
AMAP_JS_KEY=你的高德JS_KEY
AMAP_JS_SECURITY_CODE=你的高德安全密钥

# ---------- 火山引擎方舟 / 豆包（AI 生成叙事文案用，可选）----------
# 不配也能跑，只是 /api/generate_story 这个 AI 写文案的接口会报缺 key。
# 申请：https://console.volcengine.com/ark
ARK_API_KEY=你的方舟API_KEY
ARK_MODEL=doubao-seed-2-0-mini-260428
ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/responses

# ---------- 服务端口（可选，默认 8130）----------
# PORT=8130
